# Puerto de escucha (Railway lo inyecta automaticamente)
PORT=3000

# Origenes permitidos por CORS, separados por coma
# Ejemplo:
# ALLOWED_ORIGINS=https://riddleyai.vercel.app,https://www.riddleyai.com
ALLOWED_ORIGINS=https://riddleyai.vercel.app

# Conexion PostgreSQL (Railway la expone como DATABASE_URL)
DATABASE_URL=postgresql://postgres:[x1vcv545ganye]@db.jdijulceazizbycfshsq.supabase.co:5432/postgres

# En Railway suele ser true; en local puedes poner false si no usas SSL
DATABASE_SSL=true

# Base publica para audio/portadas de musica (CDN o bucket), sin slash final.
# Ejemplo: https://cdn.tudominio.com/audio
AUDIO_PUBLIC_BASE_URL=https://pub-6acb83bf77994bf89e37e7902d26564c.r2.dev/audio

# Base publica para las portadas de libros y otros uploads (sin slash final).
# Ejemplo: https://cdn.tudominio.com
IMAGE_PUBLIC_BASE_URL=https://pub-6acb83bf77994bf89e37e7902d26564c.r2.dev

